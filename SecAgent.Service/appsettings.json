{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Scanner": {
    "OutputDirectory": "C:\\ProgramData\\SecAgent\\scans",
    "ScanIntervalHours": 24,
    "RunOnStartup": true,
    "CriticalFolders": [
      "C:\\Windows\\System32",
      "C:\\Program Files",
      "C:\\ProgramData\\SecAgent",
      "C:\\Users"
    ]
  },
  "Claude": {
    "ExePath": "C:\\Users\\adria\\.local\\bin\\claude.exe",
    "TokenEnvVarName": "CLAUDE_CODE_OAUTH_TOKEN",
    "Model": "haiku",
    "TimeoutSeconds": 300,
    "ReportsDirectory": "C:\\ProgramData\\SecAgent\\reports",
    "AnalyzeAfterScan": false
  },
  "Monitors": {
    "EventsDirectory": "C:\\ProgramData\\SecAgent\\events",
    "SelfReferenceFragments": [ "SecAgent" ],
    "ProcessMonitorEnabled": true,
    "ProcessWhitelist": [],
    "SuspiciousPathFragments": [
      "\\Temp\\",
      "\\AppData\\Local\\Temp\\",
      "\\Downloads\\",
      "\\Users\\Public\\"
    ],
    "NetworkMonitorEnabled": true,
    "NetworkPollSeconds": 30,
    "NetworkPortWhitelist": [ 80, 443, 53, 123 ],
    "NetworkSnapshotEnabled": true,
    "NetworkSnapshotSeconds": 2,
    "EmitInboundEvents": true,
    "InboundPortWhitelist": [],
    "SnapshotPath": "C:\\ProgramData\\SecAgent\\network.json",
    "AlertsDirectory": "C:\\ProgramData\\SecAgent\\alerts",
    "InboundAlertCooldownMinutes": 10,
    "SensitiveInboundPorts": [ 21, 22, 23, 135, 139, 445, 1433, 3306, 3389, 5900, 5901, 5985, 5986 ],
    "EventLogMonitorEnabled": true,
    "SecurityEventIds": [ 4625, 4720, 4732, 4740, 1102 ],
    "SystemEventIds": [ 7045 ],
    "IncidentAutoAnalysisEnabled": false,
    "IncidentEventThreshold": 5,
    "IncidentWindowMinutes": 30,
    "IncidentCooldownMinutes": 60,
    "ChannelCapacity": 1000
  },
  "Triggers": {
    "TriggersDirectory": "C:\\ProgramData\\SecAgent\\triggers",
    "DebounceSeconds": 30,
    "Enabled": true
  }
}

